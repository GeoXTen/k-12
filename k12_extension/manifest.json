{
  "manifest_version": 3,
  "name": "ChatGPT K12 Bulk Invite",
  "version": "1.0",
  "description": "Bulk invite users to multiple ChatGPT K12 workspaces at once",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "K12 Bulk Invite",
    "default_icon": {
      "16": "icon128.png",
      "48": "icon128.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  }
}
